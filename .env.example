OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# 32-byte hex (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Shared secret required to sign up as an annotator (reference-key builder).
# Reviewers do not need this. Share only with people who should be annotators.
ANNOTATOR_PASSKEY=
